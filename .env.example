ANTHROPIC_API_KEY=        # Haiku review only
GEMINI_API_KEY=           # research + draft (free tier)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
DATABASE_URL=             # Neon Postgres connection string
SLACK_WEBHOOK_URL=        # for posting drafts to Slack
SLACK_SIGNING_SECRET=     # for verifying Slack interactive button payloads
APPROVAL_MODE=manual      # 'manual' until calibrated, then 'auto'
PAUSE_POSTING=            # set to 'true' as kill switch (any other value = enabled)
DRY_RUN=                  # set to 'true' to log instead of posting to Twitter
